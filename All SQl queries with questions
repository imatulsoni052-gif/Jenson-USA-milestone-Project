#--Find the total number of products sold by each store along with the store name.
SELECT 
    stores.store_name,
    stores.store_id,
    SUM(order_items.quantity) AS total_number_of_products
FROM
    orders
        JOIN
    stores ON stores.store_id = orders.store_id
        JOIN
    order_items ON orders.order_id = order_items.order_id
GROUP BY store_name , store_id;

#--Calculate the cumulative sum of quantities sold for each product over time.
SELECT order_items.product_id,
       orders.order_Date,
       order_items.quantity, 
SUM(quantity) 
OVER( PARTITION BY  order_items.product_id
 ORDER BY orders.order_date) AS
 cumulative_quantity__sold
 FROM orders JOIN order_items
 ON orders.order_id = order_items.order_id 
ORDER BY  order_items.product_id, orders.order_date;



#--Find the product with the highest total sales (quantity * price) for each category.
SELECT category_name, product_name, total_sales
FROM (
    SELECT 
        c.category_name,
        p.product_name,
        SUM(oi.quantity * oi.list_price) AS total_sales,
	       RANK() OVER (
            PARTITION BY c.category_name
            ORDER BY SUM(oi.quantity * oi.list_price) DESC
            ) AS rnk
    FROM order_items oi
    JOIN products p 
        ON oi.product_id = p.product_id
    JOIN categories c 
        ON p.category_id = c.category_id
    GROUP BY c.category_name, p.product_name) t
WHERE rnk = 1;

#Find the customer who spent the most money on orders.
SELECT customer_id, full_name, total_spending
FROM (
    SELECT 
        c.customer_id,
        CONCAT(c.first_name, ' ', c.last_name) AS full_name,
        SUM(oi.quantity * oi.list_price) AS total_spending,
        rank() OVER (
ORDER BY SUM(oi.quantity * oi.list_price) DESC) AS rnk
    FROM customers c JOIN orders o 
        ON c.customer_id = o.customer_id
    JOIN order_items oi 
        ON o.order_id = oi.order_id
    GROUP BY c.customer_id, full_name) s
WHERE rnk = 1;

#--Find the highest-priced product for each category name;
SELECT product_name, category_name, total_price FROM
(SELECT p.product_name, c.category_name , 
SUM(oi.quantity * oi.list_price) AS total_price , 
RANK () 
OVER( PARTITION BY category_name 
ORDER BY SUM(oi.quantity * oi.list_price)DESC)AS rnk 
FROM order_items oi 
JOIN products p ON oi. product_id = p.product_id 
JOIN categories c ON p.category_id = c.category_id 
GROUP BY 1,2) a
WHERE rnk = 1 ;


#--Find the total number of orders placed by each customer per store.
SELECT c.customer_id ,CONCAT
(c.first_name ,' ',c.last_name) 
 AS full_name , s.store_name,
COUNT(o.order_id) AS total_order
FROM customers c
 JOIN orders o ON c.customer_id = o.  customer_id 
 JOIN stores s ON s.store_id = o.store_id 
GROUP BY c.customer_id, full_name ,s.store_name 
ORDER BY full_name, store_name; 

#--Find the names of staff members who have not made any sales.
 SELECT CONCAT(S.first_name,' ',S.last_name)full_name,
 s.staff_id , 
 SUM(oi.quantity * oi.list_price)AS total_sales
 FROM staffs s 
 LEFT JOIN orders o
 ON s.staff_id = o.staff_id 
 LEFT JOIN order_items oi
 ON o.order_id = oi.order_id 
group by full_name, s.staff_id 
HAVING  total_sales IS NULL ;
 
#--Find the top 3 most sold products in terms of quantity.
select product_name, product_id, total_quantity from 
(SELECT p.product_name,
        p.product_id,
sum(oi.quantity ) as total_quantity,
dense_rank() over( order by sum(oi.quantity )desc)
as dns_rnk  
from products p 
join order_items oi 
on p.product_id = oi.product_id
group by p.product_name, p.product_id) as s 
where dns_rnk <= 3  ;

#--Find the median value of the price list. 
select avg(list_price) total_cnt from 
(select  list_price , row_number() 
over ( order by list_price) as rn ,
 count(*) over()as total_cnt
 from order_items) s
WHERE rn IN (
    FLOOR((total_cnt + 1) / 2) );
     
#--List all products that have never been ordered.(use Exists)
  
 
 SELECT 
    p.product_name, p.product_id
FROM
    products p
WHERE
    NOT EXISTS( SELECT 
            product_name
        FROM
            order_items oi
                JOIN
            orders o ON o.order_id = oi.order_id
        WHERE
            oi.product_id = p.product_id);
             
            
#--List the names of staff members who have made more sales than the average number of sales by all staff members.
with staff_sales as (select o.order_id,s.staff_id,
concat(s.first_name,' ',s.last_name)as full_name,
 sum(oi.quantity * oi.list_price) 
 as total_sales 
 from orders o join order_items oi 
 on o.order_id = oi.order_id 
 join staffs s 
 on s.staff_id = o.staff_id 
 group by o.order_id,s.staff_id,full_name)
  
 select order_id,staff_id,full_name,total_sales 
 from staff_sales 
 where total_sales >(select avg(total_sales)from staff_sales) ; 


#--Identify the customers who have ordered all types of products (i.e., from every category).

SELECT 
    c.customer_id,
    CONCAT(c.first_name, ' ', c.last_name) customer_name
FROM
    orders o
        JOIN
    customers c ON c.customer_id = o.customer_id
        JOIN
    order_items oi ON oi.order_id = o.order_id
        JOIN
    products p ON p.product_id = oi.product_id
GROUP BY customer_id , customer_name
HAVING COUNT(DISTINCT p.category_id) = (SELECT 
        COUNT(DISTINCT category_id)
    FROM
        products);
